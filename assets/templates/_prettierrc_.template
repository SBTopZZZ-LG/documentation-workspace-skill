{
  "printWidth": 120,
  "proseWrap": "preserve",
  "singleQuote": true,
  "trailingComma": "es5",
  "overrides": [
    {
      "files": "*.md",
      "options": {
        "proseWrap": "preserve",
        "printWidth": 120
      }
    },
    {
      "files": "*.html",
      "options": {
        "printWidth": 120
      }
    },
    {
      "files": "*.{json,yaml,yml}",
      "options": {
        "printWidth": 120
      }
    }
  ]
}
